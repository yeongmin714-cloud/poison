using UnityEngine;
using ProjectName.Core;
using ProjectName.UI;

namespace ProjectName.Systems
{
    /// <summary>
    /// 상점Placeholder - 사장님이 GLB를 제공하기 전까지 사용할 임시 상점 모델.
    /// 현재는 간단한 큐브로 표현하며, 나중에 GLB 모델로 교체됩니다.
    /// 플레이어가 E키로 상호작용하면 상점 UI를 엽니다.
    /// </summary>
    public class ShopPlaceholder : MonoBehaviour
    {
        [Header("설정")]
        [SerializeField] private string shopkeeperName = "상인";
        [SerializeField] private float _interactRange = 3f;
        
        // 참조를 위한 UIManager
        private UIManager _uiManager;
        
        // 상점 창 참조
        public ShopWindow shopWindow; // 인스펙터에서 할당

        private void Awake()
        {
            // UIManager 찾기
            _uiManager = UIManager.Instance;
            if (_uiManager == null)
            {
                Debug.LogWarning("[ShopPlaceholder] UIManager를 찾을 수 없습니다!");
            }
            
            // ShopWindow가 할당되지 않았다면 찾기 시도
            if (shopWindow == null)
            {
                shopWindow = FindObjectOfType<ShopWindow>();
                if (shopWindow == null)
                {
                    Debug.LogWarning("[ShopPlaceholder] ShopWindow를 찾을 수 없습니다!");
                }
            }
        }

        private void Start()
        {
            Debug.Log($"[ShopPlaceholder] {shopkeeperName} 상점 생성됨");
        }

        private void Update()
        {
            // 플레이어 찾기
            var player = GameObject.FindGameObjectWithTag("Player");
            if (player == null) return;

            float dist = Vector3.Distance(transform.position, player.transform.position);
            bool nearby = dist <= _interactRange;

            // E키로 상호작용
            if (nearby && Input.GetKeyDown(KeyCode.E))
            {
                OpenShop();
            }
        }

        /// <summary>
        /// 상점 UI를 엽니다.
        /// </summary>
        public void OpenShop()
        {
            if (_uiManager == null || shopWindow == null)
            {
                Debug.LogWarning("[ShopPlaceholder] UIManager 또는 ShopWindow가 설정되지 않았습니다!");
                return;
            }
            
            // 상점 창 열기
            shopWindow.Show();
            _uiManager.ToggleWindow(shopWindow);
            
            Debug.Log("[ShopPlaceholder] 상점 UI 열림");
        }

        private void OnDrawGizmosSelected()
        {
            Gizmos.color = Color.yellow;
            Gizmos.DrawWireSphere(transform.position, _interactRange);
        }
    }
}