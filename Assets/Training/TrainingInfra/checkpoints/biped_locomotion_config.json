{
  "avatar": "biped",
  "obs_dim": 120,
  "act_dim": 80,
  "joint_count": 18,
  "device": "cpu",
  "hidden_sizes": [
    256,
    128,
    64
  ],
  "activation": "tanh",
  "use_layer_norm": false,
  "shared_backbone": true,
  "actor_lr": 0.0003,
  "critic_lr": 0.0003,
  "lr_schedule": "linear",
  "lr_final": 1e-05,
  "clip_epsilon": 0.2,
  "entropy_coef": 0.01,
  "value_loss_coef": 0.5,
  "max_grad_norm": 0.5,
  "target_kl": 0.02,
  "gamma": 0.99,
  "gae_lambda": 0.95,
  "n_steps": 2048,
  "batch_size": 64,
  "mini_epochs": 10,
  "normalize_advantages": true,
  "clip_value_loss": true,
  "anneal_entropy": true,
  "entropy_final": 0.001,
  "total_epochs": 100,
  "steps_per_epoch": 50000,
  "eval_interval": 10,
  "eval_episodes": 5,
  "save_interval": 25,
  "log_interval": 1,
  "checkpoint_dir": "models",
  "experiment_name": "neural_animation_ppo",
  "seed": 42,
  "input_name": "observation",
  "output_name": "action",
  "opset_version": 17,
  "dynamic_batch": true,
  "export_fp16": false,
  "input_shape_nhwc": [
    1,
    1,
    1,
    -1
  ],
  "dt": 0.02,
  "physics_steps": 2,
  "reward_velocity_weight": 1.0,
  "reward_energy_weight": 0.1,
  "reward_smoothness_weight": 0.05,
  "reward_pose_weight": 0.3,
  "reward_contact_weight": 0.1,
  "max_episode_length": 1000,
  "observation_noise": 0.01,
  "action_noise": 0.0,
  "target_velocity_range": [
    0.5,
    5.0
  ]
}